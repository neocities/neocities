<%
  has_editor = @page < TUTORIAL_PAGE_COUNT
  review_page = @page == TUTORIAL_COMPLETION_PAGE
  if @page == TUTORIAL_COMPLETION_PAGE - 1
    next_url = "/tutorial/#{@section}/#{TUTORIAL_COMPLETION_PAGE}?csrf_token=#{Rack::Utils.escape csrf_token}"
  else
    next_url = "/tutorial/#{@section}/#{@page + 1}"
  end
%>
<section class="section tutorial">
  <nav class="tutorial-Progress" aria-label="Tutorial progress">
    <% 1.upto(TUTORIAL_PAGE_COUNT) do |p| %>
      <% classes = ['tutorial-Step'] %>
      <% classes << 'is-Current' if p == @page %>
      <% classes << 'is-Done' if p < @page %>
      <% if p < @page %>
        <% step_url = p == TUTORIAL_COMPLETION_PAGE ? "/tutorial/#{@section}/#{p}?csrf_token=#{Rack::Utils.escape csrf_token}" : "/tutorial/#{@section}/#{p}" %>
        <a href="<%= step_url %>" class="<%= classes.join(' ') %>" title="<%= tutorial_page_title(p) %>"><%= p %></a>
      <% else %>
        <span class="<%= classes.join(' ') %>" title="<%= tutorial_page_title(p) %>"<%== p == @page ? ' aria-current="step"' : '' %>><%= p %></span>
      <% end %>
    <% end %>
  </nav>

  <div class="row">
    <div class="col <%= has_editor ? 'col-50' : 'col-100' %> lesson">
      <p class="step-Count">HTML Tutorial &middot; Step <%= @page %> of <%= TUTORIAL_PAGE_COUNT %></p>
      <h1><%= tutorial_page_title(@page) %></h1>

      <%== erb "tutorial/#{@section}/#{@page}".to_sym, layout: false %>

      <% if @page > 1 && has_editor %>
        <p class="lesson-Nav"><a href="/tutorial/<%= @section %>/<%= @page - 1 %>">&laquo; Back to the previous step</a></p>
      <% end %>
    </div>

    <% if has_editor %>
    <div class="col col-50 interact">
      <% unless review_page %>
        <div class="interact-Actions">
          <a href="#" id="checkButton" class="btn btn-Action">Check My Work</a>
          <a href="#" id="resetButton" class="btn cancel">Reset This Step</a>
        </div>

        <div id="tutorialFeedback" class="tutorial-Feedback" style="display: none" role="status" aria-live="polite"></div>
      <% end %>

      <h3 class="editor-heading"><%= review_page ? 'Your finished code' : 'Your code (edit me!)' %></h3>
      <div id="editor" class="editor"><%= tutorial_starter_html(@page) %></div>

      <h3 class="preview-heading">What visitors will see</h3>
      <div class="preview-Browser">
        <div class="preview-Chrome">
          <span class="preview-Dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="preview-Tab"><i class="fa fa-file-o" aria-hidden="true"></i> <span id="previewTabTitle">Untitled page</span></span>
        </div>
        <div class="preview-UrlBar"><i class="fa fa-lock" aria-hidden="true"></i> <%= current_site.host %></div>
        <iframe id="previewFrame" class="preview" sandbox="allow-same-origin" title="Live preview of your page"></iframe>
      </div>
    </div>
    <% end %>
  </div>
</section>

<% if has_editor %>
<script src="/js/ace/ace.js" type="text/javascript" charset="utf-8"></script>
<% end %>

<script>
  var TUTORIAL = {
    page: <%= @page %>,
    pageCount: <%= TUTORIAL_PAGE_COUNT %>,
    nextUrl: '<%== escape_javascript next_url %>',
    hasEditor: <%= has_editor %>,
    reviewPage: <%= review_page %>,
    storageKey: 'neocities_tutorial_html:<%== escape_javascript current_site.username %>'
  }

  var defaultTutorialHtml = '<%== escape_javascript tutorial_starter_html(@page) %>'

  function tutorialLoadSavedHtml() {
    try {
      return localStorage.getItem(TUTORIAL.storageKey)
    } catch(e) {
      return null
    }
  }

  function tutorialSaveHtml(html) {
    try {
      localStorage.setItem(TUTORIAL.storageKey, html)
    } catch(e) {}
  }

  // --- Helpers available to each lesson's check function ---

  function parseHtml(html) {
    return new DOMParser().parseFromString(html, 'text/html')
  }

  function bodyText(doc) {
    return (doc.body ? doc.body.textContent : '').replace(/\s+/g, ' ').trim()
  }

  // True when there are more opening <tag>s than closing </tag>s,
  // which almost always means the student forgot a closing tag.
  function missingClosingTag(html, tag) {
    var openings = (html.match(new RegExp('<' + tag + '(\\s|>)', 'gi')) || []).length
    var closings = (html.match(new RegExp('</' + tag + '\\s*>', 'gi')) || []).length
    return closings < openings
  }

  function escapeText(text) {
    return $('<span>').text(text).html()
  }

  function codeSample(code) {
    return '<code>' + escapeText(code) + '</code>'
  }

  // --- Feedback UI ---

  var feedbackObj = $('#tutorialFeedback')

  function hint(messageHtml) {
    feedbackObj.attr('class', 'tutorial-Feedback is-Hint')
    feedbackObj.html('<i class="fa fa-lightbulb-o" aria-hidden="true"></i> ' + messageHtml)
    feedbackObj.fadeIn('fast')
  }

  function success(messageHtml) {
    feedbackObj.attr('class', 'tutorial-Feedback is-Success')
    feedbackObj.html('<i class="fa fa-check-circle" aria-hidden="true"></i> ' + messageHtml +
      ' <a href="' + TUTORIAL.nextUrl + '" class="feedback-Next">Next step &raquo;</a>')
    feedbackObj.fadeIn('fast')
  }

  // --- Editor, preview and homework checking ---

  var editor

  // The preview iframe is sandboxed without scripts, so links inside it can't
  // open pages themselves - and letting them navigate the iframe broke on
  // sites that refuse to be framed. Instead, catch clicks from the parent
  // (the frame is same-origin) and open links in a new tab, resolving
  // relative addresses against the student's real site like a published
  // page would.
  function interceptPreviewLinks() {
    var frame = document.getElementById('previewFrame')
    var doc = frame && frame.contentDocument
    if(!doc)
      return

    doc.addEventListener('click', function(e) {
      var target = e.target
      var link = target.closest ? target.closest('a[href]') : null
      if(!link)
        return

      e.preventDefault()

      var href = link.getAttribute('href')
      if(!href || href.charAt(0) == '#')
        return

      var url
      try {
        url = new URL(href, 'https://<%== escape_javascript current_site.host %>/')
      } catch(err) {
        return
      }

      if(url.protocol == 'http:' || url.protocol == 'https:')
        window.open(url.href, '_blank', 'noopener')
    }, true)
  }

  function refreshPreview() {
    if(!editor)
      return

    var html = editor.getValue()
    var frame = document.getElementById('previewFrame')

    if(frame)
      frame.srcdoc = html

    var doc = parseHtml(html)
    var titleTag = doc.querySelector('title')
    var tabTitle = titleTag ? titleTag.textContent.trim() : ''
    $('#previewTabTitle').text(tabTitle == '' ? 'Untitled page' : tabTitle)
  }

  function checkHomework() {
    if(typeof lessonCheck === 'undefined')
      return

    var html = editor.getValue()
    var result = lessonCheck(parseHtml(html), html)

    if(result.ok) {
      tutorialSaveHtml(html)
      success(result.message)
    } else {
      hint(result.message)
    }
  }

  var refreshTimer, saveTimer

  $(document).ready(function() {
    // hljs.highlightAll() only covers <pre><code> blocks; color the inline
    // code chips in the lesson too. The tag anatomy diagram is skipped: its
    // fragments (like a lone opening tag) are too partial for the parser,
    // so its pieces are hand-colored with anatomy-* classes instead.
    document.querySelectorAll('.tutorial .lesson code').forEach(function(el) {
      if(el.closest('.tag-Anatomy') || el.classList.contains('hljs'))
        return
      el.classList.add('html')
      hljs.highlightElement(el)
    })

    if(!TUTORIAL.hasEditor)
      return

    editor = ace.edit('editor')
    editor.setTheme('ace/theme/tomorrow_night')
    editor.getSession().setMode('ace/mode/html')
    editor.getSession().setTabSize(2)
    editor.getSession().setUseWrapMode(true)
    editor.setFontSize(14)
    editor.setShowPrintMargin(false)
    editor.setOptions({
      maxLines: Infinity,
      autoScrollEditorIntoView: true
    })

    // Disable bracket/tag autocompletion - beginners should type both tags themselves
    editor.setBehavioursEnabled(false)

    var savedHtml = tutorialLoadSavedHtml()
    if(savedHtml)
      editor.setValue(savedHtml, -1)

    if(TUTORIAL.reviewPage) {
      editor.setReadOnly(true)
    } else {
      editor.on('change', function() {
        feedbackObj.fadeOut('fast')

        clearTimeout(refreshTimer)
        refreshTimer = setTimeout(refreshPreview, 200)

        clearTimeout(saveTimer)
        saveTimer = setTimeout(function() {
          tutorialSaveHtml(editor.getValue())
        }, 500)
      })

      editor.commands.addCommand({
        name: 'saveCommand',
        bindKey: {win: 'Ctrl-S', mac: 'Command-S'},
        exec: function() {
          checkHomework()
        }
      })
    }

    var previewFrame = document.getElementById('previewFrame')
    if(previewFrame)
      previewFrame.addEventListener('load', interceptPreviewLinks)

    refreshPreview()

    $('#checkButton').on('click', function(e) {
      e.preventDefault()
      this.blur()
      checkHomework()
    })

    $('#resetButton').on('click', function(e) {
      e.preventDefault()
      this.blur()
      if(confirm('This replaces your work with the example page for this step. Reset?')) {
        editor.setValue(defaultTutorialHtml, -1)
        tutorialSaveHtml(defaultTutorialHtml)
        refreshPreview()
        feedbackObj.fadeOut('fast')
      }
    })
  })
</script>
