<div class="bonus-Box">
  <h4>Why bother with the wrapper?</h4>
  <p>Right now, calling the function once seems like extra steps. But a named trick can be performed <em>whenever something happens</em> &mdash; a click, a keypress, a timer. Next step, we hand the <code>changeSky()</code> call to a button and let your visitors do it.</p>
</div>

<script>
  function lessonCheck(doc, html) {
    var js = scriptText(doc)

    var definition = js.match(/function\s+([a-zA-Z_$][\w$]*)\s*\(\s*\)\s*\{/)

    if(!definition) {
      if(/function/i.test(js))
        return {ok: false, message: 'A function definition looks like ' + codeSample('function changeSky() {') + ' &mdash; the word function, a name, empty parentheses, then an opening curly brace.'}
      return {ok: false, message: 'I don&rsquo;t see a function yet. Teach the page a trick: ' + codeSample('function changeSky() { ... }')}
    }

    var name = definition[1]
    var uses = js.match(new RegExp('\\b' + name + '\\s*\\(', 'g')) || []

    if(uses.length < 2)
      return {ok: false, message: 'You taught the trick &mdash; now perform it! Add ' + codeSample(name + '()') + ' on its own line at the bottom of the script.'}

    var braces = (js.match(/\{/g) || []).length - (js.match(/\}/g) || []).length
    if(braces > 0)
      return {ok: false, message: 'A curly brace never got closed &mdash; every ' + codeSample('{') + ' needs its ' + codeSample('}') + '. Count yours!'}

    return {ok: true, message: 'Defined, then called &mdash; and the sky obeyed. That&rsquo;s the heart of all programming.'}
  }
</script>
