<table class="cheat-Sheet">
  <thead>
    <tr><th>CSS</th><th>What it does</th></tr>
  </thead>
  <tbody>
    <tr><td><code>selector { property: value; }</code></td><td>The shape of every rule in CSS</td></tr>
    <tr><td><code>h1 { color: ... }</code></td><td>Element selectors style every matching element</td></tr>
    <tr><td><code>#ffe9f0</code></td><td>Hex codes: any of 16 million colors</td></tr>
    <tr><td><code>font-family</code></td><td>The page's typeface, with fallbacks after commas</td></tr>
    <tr><td><code>.intro { ... }</code></td><td>Class selectors style the parts you've named</td></tr>
    <tr><td><code>padding</code>, <code>border</code>, <code>margin</code></td><td>Inside space, the edge, outside space</td></tr>
    <tr><td><code>border-radius</code></td><td>Rounded corners</td></tr>
    <tr><td><code>max-width</code> + <code>margin: 0 auto</code></td><td>The centered-column spell</td></tr>
    <tr><td><code>a:hover { ... }</code></td><td>Styles that apply while the mouse is over</td></tr>
    <tr><td><code>linear-gradient(a, b)</code></td><td>A background that blends between colors</td></tr>
  </tbody>
</table>

