    <tr><td><code>#d9f2e6</code></td><td><span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:#d9f2e6;border:1px solid rgba(0,0,0,.25)"></span></td><td>Seafoam</td></tr>
