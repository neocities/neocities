<div class="bonus-Box">
  <h4>Patterns, tiles, and full wallpaper</h4>
  <p>The <code>background</code> property has more tricks: <code>background: url("/mypattern.png");</code> tiles an image across the page &mdash; the beloved wallpaper look of the classic web. Upload any small image to your site from the dashboard and try it. Gradients not blending? Make sure both colors are inside the parentheses, separated by a comma.</p>
</div>

<script>
  function lessonCheck(doc, html) {
    var css = styleText(doc)

    if(/background-color\s*:\s*linear-gradient/i.test(css))
      return {ok: false, message: 'Ah, the classic trap! ' + codeSample('background-color') + ' only holds solid colors &mdash; use the bigger property: ' + codeSample('background: linear-gradient(lightskyblue, plum);')}

    var gradient = css.match(/background\s*:\s*linear-gradient\s*\(([^)]*)\)/i)

    if(!gradient) {
      if(/linear\s*-?\s*gradient/i.test(css))
        return {ok: false, message: 'I can see a gradient forming &mdash; check the spelling and shape: ' + codeSample('background: linear-gradient(lightskyblue, plum);')}
      return {ok: false, message: 'No gradient yet! In your body rule, swap the background-color line for ' + codeSample('background: linear-gradient(lightskyblue, plum);')}
    }

    if(gradient[1].indexOf(',') == -1)
      return {ok: false, message: 'A gradient needs at least two colors to blend between, separated by a comma: ' + codeSample('linear-gradient(lightskyblue, plum)')}

    if(!/min-height\s*:\s*[^;\s}]/i.test(css))
      return {ok: false, message: 'Gorgeous &mdash; but look at the bottom of a tall window: the sky runs out where your words do, then starts over. Add ' + codeSample('min-height: 100vh;') + ' to the body rule so it always reaches the ground.'}

    return {ok: true, message: 'You painted a sky with one line of CSS, and it goes all the way down. What a finish!'}
  }
</script>
