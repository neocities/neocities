<div class="settings-section-heading">
  <span class="settings-section-icon"><i class="fa fa-lock"></i></span>
  <div>
    <h2>Change password</h2>
    <p>Keep your account secure with a password you do not use anywhere else.</p>
  </div>
</div>

<div class="settings-form-layout">
  <form method="POST" action="/settings/change_password" class="settings-form settings-form-card">
    <%== csrf_token_input_html %>

    <% unless current_site.password_reset_confirmed %>
      <div class="settings-field">
        <label for="current_password">Current password</label>
        <input id="current_password" class="input-Area" name="current_password" type="password" autocomplete="current-password">
      </div>
    <% end %>

    <div class="settings-field">
      <label for="new_password">New password</label>
      <input id="new_password" class="input-Area" name="new_password" type="password" autocomplete="new-password" minlength="<%= Site::MINIMUM_PASSWORD_LENGTH %>">
      <small>At least <%= Site::MINIMUM_PASSWORD_LENGTH %> characters.</small>
    </div>

    <div class="settings-field">
      <label for="new_password_confirm">Confirm new password</label>
      <input id="new_password_confirm" class="input-Area" name="new_password_confirm" type="password" autocomplete="new-password" minlength="<%= Site::MINIMUM_PASSWORD_LENGTH %>">
    </div>

    <div class="settings-actions">
      <input class="btn-Action" type="submit" value="Change Password">
    </div>
  </form>

  <aside class="settings-tip-card">
    <i class="fa fa-shield"></i>
    <div>
      <strong>A stronger password is easier to remember than to guess</strong>
      <ul>
        <li>Use a long phrase or several unrelated words.</li>
        <li>Avoid names, dates, and reused passwords.</li>
        <li>Store it in a password manager if you use one.</li>
      </ul>
    </div>
  </aside>
</div>
