<div class="settings-section-heading">
  <span class="settings-section-icon settings-section-icon-danger"><i class="fa fa-trash"></i></span>
  <div>
    <h2>Delete site</h2>
    <p>Remove this website and its files from Neocities.</p>
  </div>
</div>

<% if @site.parent? && @site.children_dataset.where(is_deleted: false).count > 0 %>
  <div class="settings-blocked-card">
    <i class="fa fa-ban"></i>
    <div>
      <strong>This site cannot be deleted yet</strong>
      <p>You cannot delete the parent site without deleting the children sites first.</p>
      <a href="/settings#sites">Return to your sites</a>
    </div>
  </div>
<% else %>
  <div class="settings-delete-warning">
    <span><i class="fa fa-exclamation-triangle"></i></span>
    <div>
      <strong>This action is dangerous</strong>
      <ul>
        <li>All files for <strong><%= @site.host %></strong> will be deleted.</li>
        <li>This username can not be used to create another site.</li>
        <% if @site.parent? %>
          <li>Your email address cannot be used to register another Neocities account.</li>
        <% end %>
      </ul>
    </div>
  </div>

  <form method="POST" action="/settings/<%= @site.username %>/delete" class="settings-form settings-delete-form">
    <%== csrf_token_input_html %>
    <% if @site.parent? %>
      <div class="settings-field">
        <label for="deleted_reason">Why are you deleting your site? <span class="settings-optional">Optional</span></label>
        <textarea id="deleted_reason" name="deleted_reason" placeholder="Your feedback can help us improve."></textarea>
      </div>
    <% end %>

    <div class="settings-field">
      <label for="confirm_username">Type <strong><%= @site.username %></strong> to confirm</label>
      <div class="settings-domain-input">
        <input id="confirm_username" name="confirm_username" type="text" autocapitalize="off" autocorrect="off" autocomplete="off" spellcheck="false">
        <span>.neocities.org</span>
      </div>
    </div>

    <div class="settings-actions">
      <input class="btn-Action settings-delete-button" type="submit" value="Delete Site">
    </div>
  </form>
<% end %>
