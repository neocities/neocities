<div class="settings-section-heading">
  <span class="settings-section-icon"><i class="fa fa-money"></i></span>
  <div>
    <h2>Site tipping</h2>
    <p>Let visitors support your work from the Neocities profile for this site.</p>
  </div>
</div>

<form method="POST" action="/settings/<%= current_site.username %>/tipping" class="settings-form">
  <%== csrf_token_input_html %>

  <label class="settings-feature-toggle">
    <span class="settings-toggle-icon"><i class="fa fa-heart"></i></span>
    <span><strong>Show the “Send a Tip” button</strong><small>Visitors will see the tipping option on your site profile.</small></span>
    <input name="site[tipping_enabled]" type="hidden" value="false">
    <input class="settings-toggle-input" name="site[tipping_enabled]" type="checkbox" value="true"
      <% if current_site.tipping_enabled == true %>checked<% end %>
    >
    <span class="settings-switch" aria-hidden="true"></span>
  </label>

  <div class="settings-payment-options">
    <section class="settings-payment-option">
      <span class="settings-card-icon"><i class="fa fa-paypal"></i></span>
      <div>
        <h3>PayPal</h3>
        <p>Tips open PayPal with this address as the recipient.</p>
        <label for="tipping_paypal">PayPal email address</label>
        <input id="tipping_paypal" name="site[tipping_paypal]" type="email" class="input-Area" autocomplete="email" autocapitalize="off" autocorrect="off" value="<%= current_site.tipping_paypal %>" placeholder="you@example.com">
      </div>
    </section>

    <section class="settings-payment-option">
      <span class="settings-card-icon"><i class="fa fa-btc"></i></span>
      <div>
        <h3>Bitcoin</h3>
        <p>Optionally let visitors send Bitcoin to your wallet.</p>
        <label for="tipping_bitcoin">Bitcoin address</label>
        <input id="tipping_bitcoin" name="site[tipping_bitcoin]" type="text" class="input-Area settings-mono-input" autocapitalize="off" autocorrect="off" spellcheck="false" value="<%= current_site.tipping_bitcoin %>" placeholder="Wallet address">
      </div>
    </section>
  </div>

  <div class="settings-privacy-note"><i class="fa fa-eye"></i><span>The PayPal email or Bitcoin address you enter will be visible to visitors who choose to tip.</span></div>

  <div class="settings-actions">
    <input class="btn-Action" type="submit" value="Save Changes">
  </div>
</form>
