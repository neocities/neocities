<% tags_count = @site.tags_dataset.count %>
<% tags_remaining = Site::MAXIMUM_TAGS - tags_count %>

<div class="settings-tags" id="settings-tags">
  <div class="settings-section-heading">
    <span class="settings-section-icon"><i class="fa fa-tags"></i></span>
    <div>
      <h2>Discovery tags</h2>
      <p>Help people find your site on <a href="/browse">Browse</a> with a few clear, descriptive topics.</p>
    </div>
  </div>

  <div class="settings-tag-summary">
    <div class="settings-tag-summary-top">
      <div><span class="settings-kicker">Your tags</span><strong><%= tags_count %> of <%= Site::MAXIMUM_TAGS %> used</strong></div>
      <span><%= tags_remaining %> remaining</span>
    </div>
    <div class="settings-tag-progress"><span style="width: <%= tags_count * 100 / Site::MAXIMUM_TAGS %>%"></span></div>
    <% if tags_count.zero? %>
      <div class="settings-empty-state"><i class="fa fa-tags"></i><span>No tags yet. Add a few below to help visitors discover your site.</span></div>
    <% else %>
      <div class="tag-pill-row">
        <% @site.tags.each do |tag| %>
          <span class="tag-pill"><%= tag.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="settings-action-grid">
    <section class="settings-action-card">
      <span class="settings-card-icon"><i class="fa fa-plus"></i></span>
      <h3>Add tags</h3>
      <% if tags_count >= Site::MAXIMUM_TAGS %>
        <p>You have reached the maximum. Remove a tag before adding another.</p>
      <% else %>
        <p>Use letters and numbers, and separate multiple tags with commas.</p>
        <form method="POST" action="/settings/<%= @site.username %>/tags/add" class="tag-form">
          <%== csrf_token_input_html %>
          <label for="site_tags">Tags</label>
          <input id="site_tags"
                 type="text"
                 name="tags"
                 class="input-Area typeahead"
                 placeholder="art, music, personal"
                 autocapitalize="off"
                 autocorrect="off"
                 autocomplete="off"
                 spellcheck="false">
          <button class="btn-Action" type="submit">Add Tag(s)</button>
        </form>
      <% end %>
    </section>

    <section class="settings-action-card">
      <span class="settings-card-icon"><i class="fa fa-minus"></i></span>
      <h3>Remove tags</h3>
      <% if tags_count.zero? %>
        <p>Once you add tags, you can select and remove them here.</p>
      <% else %>
        <p>Select any tags you no longer want associated with your site.</p>
        <form method="POST" action="/settings/<%= @site.username %>/tags/remove" class="tag-form">
          <%== csrf_token_input_html %>
          <div class="tag-chip-grid">
            <% @site.tags.each do |tag| %>
              <label class="tag-chip">
                <input name="tags[]" type="checkbox" value="<%= tag.name %>">
                <span><%= tag.name %></span>
              </label>
            <% end %>
          </div>
          <button class="settings-remove-button" type="submit"><i class="fa fa-trash"></i> Remove Selected</button>
        </form>
      <% end %>
    </section>
  </div>
</div>
