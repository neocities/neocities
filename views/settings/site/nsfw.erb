<div class="settings-section-heading">
  <span class="settings-section-icon"><i class="fa fa-eye-slash"></i></span>
  <div>
    <h2>18+ content</h2>
    <p>Classify this site so visitors can make an informed choice before viewing it.</p>
  </div>
</div>

<div class="settings-classification-note">
  <i class="fa fa-info-circle"></i>
  <div>
    <strong>Marking a site 18+ does not remove it.</strong>
    <p>It changes how the site appears on Browse and helps keep mature material away from visitors who do not want to see it. Use this setting for sites with content that is not age appropriate for all users.</p>
  </div>
</div>

<form method="POST" action="/settings/<%= @site.username %>/change_nsfw" class="settings-form">
  <%== csrf_token_input_html %>
  <input name="is_nsfw" type="hidden" value="false">
  <label class="settings-feature-toggle settings-feature-toggle-warning">
    <span class="settings-toggle-icon"><i class="fa fa-eye-slash"></i></span>
    <span><strong>This site contains 18+ content</strong></span>
    <input class="settings-toggle-input" name="is_nsfw" type="checkbox" value="true"
      <% if @site.is_nsfw %>checked<% end %>
    >
    <span class="settings-switch" aria-hidden="true"></span>
  </label>

  <div class="settings-actions">
    <input class="btn-Action" type="submit" value="Update">
  </div>
</form>