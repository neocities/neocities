<div class="settings-section-heading">
  <span class="settings-section-icon"><i class="fa fa-key"></i></span>
  <div>
    <h2>API key</h2>
    <p>Deploy and manage files with the <a href="/api">Neocities API</a> without sharing your password.</p>
  </div>
</div>

<div class="settings-danger-note">
  <i class="fa fa-shield"></i>
  <div><strong>Treat this key like a password.</strong><span>It gives full write access to this site. Never put it in public code, screenshots, or support messages.</span></div>
</div>

<% if @site.api_key %>
  <div class="settings-key-card">
    <span class="settings-kicker">Active API key</span>
    <code><%= @site.api_key %></code>
  </div>

  <div class="settings-regenerate-row">
    <div><strong>Need a new key?</strong><p>Generating another key immediately disables the one shown above.</p></div>
    <%== erb :'settings/site/_api_key_form', layout: false, locals: {confirm_regeneration: true} %>
  </div>
<% else %>
  <div class="settings-empty-action">
    <span class="settings-card-icon"><i class="fa fa-key"></i></span>
    <div><strong>No API key yet</strong><p>Generate one when you are ready to use a deployment tool or the API.</p></div>
    <%== erb :'settings/site/_api_key_form', layout: false, locals: {confirm_regeneration: false} %>
  </div>
<% end %>
